---
layout: default
---
{% assign year = page.date | date: '%Y' %}
{% assign tags = page.tags | join: '' %}
{% assign categories = page.categories | join: '' %}
{% assign is_note = false %}
{% if page.collection == 'notes' %}
  {% assign is_note = true %}
{% endif %}

{% if page._styles %}
  <!-- Page/Post style -->
  <style type="text/css">
    {{ page._styles }}
  </style>
{% endif %}

{% assign url_beginning = page.url | slice: 0, 6 %}

<div class="post{% if is_note %} post-shell research-note{% endif %}">
  {% if is_note %}
    <header class="post-header note-post-header">
      <div class="post-kicker-row">
        <span class="post-kicker">{{ page.eyebrow | default: 'Research Note' }}</span>
        {% if page.series %}
          <span class="post-chip subtle">{{ page.series }}</span>
        {% endif %}
      </div>

      <h1 class="post-title">{{ page.title }}</h1>

      {% if page.description %}
        <p class="post-deck">{{ page.description }}</p>
      {% endif %}

      <div class="post-meta-row">
        <span class="post-chip">{{ page.date | date: '%B %d, %Y' }}</span>
        {% if page.reading_time %}
          <span class="post-chip">{{ page.reading_time }} read</span>
        {% endif %}
        {% if page.difficulty %}
          <span class="post-chip">{{ page.difficulty }}</span>
        {% endif %}
        {% if page.meta %}
          <span class="post-chip">{{ page.meta }}</span>
        {% endif %}
      </div>

      {% if page.tags %}
        <div class="post-topic-row">
          {% for tag in page.tags %}
            <span class="post-topic">{{ tag }}</span>
          {% endfor %}
        </div>
      {% endif %}

      {% if page.key_takeaways %}
        <div class="post-takeaways">
          <p class="post-takeaways-label">What this note covers</p>
          <ul>
            {% for takeaway in page.key_takeaways %}
              <li>{{ takeaway }}</li>
            {% endfor %}
          </ul>
        </div>
      {% endif %}
    </header>
  {% else %}
    <header class="post-header">
      <h1 class="post-title">{{ page.title }}</h1>
      <p class="post-meta">
        Created in {{ page.date | date: '%B %d, %Y' }}
        {% if page.author %}by {{ page.author }}{% endif %}
        {% if page.last_updated %}, last updated in {{ page.last_updated | date: '%B %d, %Y' }}{% endif %}
        {% if page.meta %}• {{ page.meta }}{% endif %}
      </p>
      <p class="post-tags">
        {% if url_beginning == '/blog/' %}
          <a href="{{ year | prepend: '/blog/' | prepend: site.baseurl}}"> <i class="fa-solid fa-calendar fa-sm"></i> {{ year }} </a>
        {% else %}
          <i class="fa-solid fa-calendar fa-sm"></i> {{ year }}
        {% endif %}
        {% if tags != '' %}
          &nbsp; &middot; &nbsp;
          {% for tag in page.tags %}
            {% if url_beginning == '/blog/' %}
              <a href="{{ tag | slugify | prepend: '/blog/tag/' | prepend: site.baseurl}}"> <i class="fa-solid fa-hashtag fa-sm"></i> {{ tag }}</a>
            {% else %}
              <i class="fa-solid fa-hashtag fa-sm"></i> {{ tag }}
            {% endif %}
            {% unless forloop.last %}
              &nbsp;
            {% endunless %}
          {% endfor %}
        {% endif %}

        {% if categories != '' %}
          &nbsp; &middot; &nbsp;
          {% for category in page.categories %}
            {% if url_beginning == '/blog/' %}
              <a href="{{ category | slugify | prepend: '/blog/category/' | prepend: site.baseurl}}">
                <i class="fa-solid fa-tag fa-sm"></i> {{ category -}}
              </a>
            {% else %}
              <i class="fa-solid fa-tag fa-sm"></i> {{ category }}
            {% endif %}
            {% unless forloop.last %}
              &nbsp;
            {% endunless %}
          {% endfor %}
        {% endif %}
      </p>
    </header>
  {% endif %}

  <article class="post-content{% if is_note %} research-note-content{% endif %}">
    {% if page.toc and page.toc.beginning %}
      <div id="table-of-contents">
        {% toc %}
      </div>
      <hr>
    {% endif %}
    <div id="markdown-content">
      {{ content }}
    </div>
  </article>

  {% if page.citation %}
    {% include citation.liquid %}
  {% endif %}

  {% if page.related_publications %}
    <h2>References</h2>
    <div class="publications">
      {% bibliography --cited_in_order %}
    </div>
  {% endif %}

  {% if is_note %}
    {% assign related_notes = site.notes | where_exp: 'note', 'note.url != page.url' | sort: 'date' | reverse %}
    {% if related_notes.size > 0 %}
      <section class="related-notes">
        <div class="notes-section-heading">
          <div>
            <p class="notes-section-kicker">Continue Reading</p>
            <h2>More research notes</h2>
          </div>
          <p class="notes-section-copy">A few nearby topics if you want to keep going.</p>
        </div>
        <div class="note-card-grid related-note-grid">
          {% for note in related_notes limit: 2 %}
            {% include note_card.liquid note=note compact=true %}
          {% endfor %}
        </div>
      </section>
    {% endif %}
  {% endif %}

  {% if site.disqus_shortname and page.disqus_comments %}
    {% include disqus.liquid %}
  {% endif %}
  {% if site.giscus and page.giscus_comments %}
    {% include giscus.liquid %}
  {% endif %}
</div>
